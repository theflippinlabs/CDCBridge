{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:shared && npm run build --workspace @vaultbridge/frontend",
  "outputDirectory": "apps/frontend/dist",
  "installCommand": "npm install",
  "framework": null,
  "headers": [
    {
      "source": "/((?!assets/).*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://vaultbridgebackend-production.up.railway.app/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
