# ──────────────────────────────────────────────────────────────────────────
# VaultBridge — Environment Variables (example)
# Copy to .env (root), apps/backend/.env and apps/frontend/.env as needed.
# NEVER commit real secrets. NEVER store Crypto.com credentials anywhere.
# ──────────────────────────────────────────────────────────────────────────

# ── Supabase (shared) ─────────────────────────────────────────────────────
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# anon/public key — safe for the browser (frontend)
SUPABASE_ANON_KEY=
# service role key — BACKEND ONLY. Never expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret used to verify Supabase access tokens on the backend.
# Find it in Supabase Dashboard → Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# ── Backend (apps/backend/.env) ───────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:5173

# ── Frontend (apps/frontend/.env) ─────────────────────────────────────────
# Vite only exposes vars prefixed with VITE_ to the browser.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=http://localhost:4000

# ── Stripe (OPTIONAL — billing is NOT activated in this MVP) ───────────────
# Left here so the structure is ready. Do not enable billing yet.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
